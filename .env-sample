# APP
NODE_ENV=development
PORT=8000
APP_NAME=ReelCore
API_PREFIX=/api/v1

# DATABASE
DATABASE_URL=mongodb://localhost:27017/reel_core

# REDIS
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URI=

# JWT
JWT_ACCESS_SECRET=your_super_secure_access_secret
JWT_REFRESH_SECRET=your_super_secure_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# BCRYPT
BCRYPT_SALT_ROUNDS=12

# STORAGE (S3 / MINIO)
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ap-south-1
S3_BUCKET=reel-core-media
S3_ENDPOINT=

# CORS
CORS_ORIGIN=http://localhost:3000

# LOGGING
LOG_LEVEL=debug

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# VIDEO PROCESSING
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# QUEUES
VIDEO_PROCESSING_QUEUE=video-processing
RECOMMENDATION_QUEUE=recommendation-engine
ANALYTICS_QUEUE=analytics-events

# ANALYTICS / EVENTS
ENABLE_ANALYTICS=true

# FEATURE FLAGS
ENABLE_RECOMMENDATION_ENGINE=true
ENABLE_VIDEO_TRANSCODING=true
ENABLE_SWAGGER=true
